#include <stdio.h>
#include <math.h>

float juros_compostos(float capital, float taxa, int tempo) {
    taxa = taxa / 100.0;
    return capital * pow(1 + taxa, tempo);
}

int main() {
    float capital, taxa;
    int tempo;

    printf("Valor investido: ");
    scanf("%f", &capital);

    printf("Taxa de juros (%%): ");
    scanf("%f", &taxa);

    printf("Tempo: ");
    scanf("%d", &tempo);

    float total = juros_compostos(capital, taxa, tempo);

    printf("Total final: %.2f\n", total);

    return 0;
}
